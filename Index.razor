    <section id="builds" class="section">
        <div class="section-heading">
            <h2>Builds</h2>
            <p>Selected projects and product work.</p>
        </div>
        <div class="card-grid">
            <article class="card">
                <h3>5" Freestyle FPV Drone</h3>
                <p>
                    An aggressive beast, built for freestyle. Cinematic shots are possible.
                    This beast has brutal pitch and real power even if it looks small.
                    Don't underestimate it.
                </p>
            </article>
            <article class="card">
                <h3>COMING SOON</h3>
                <p>More builds coming soon.</p>
            </article>
        </div>
    </section>

    <!-- Clips Section -->
    <section id="clips" class="section alt">
        <div class="section-heading">
            <h2>Clips</h2>
            <p>Sum clips.</p>
        </div>
        <div class="clips-grid">
            <article class="clip-card">
                <div class="video-container">
                    <iframe src="https://www.youtube.com/embed/nBUZs_E-DSU"
