                            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                            allowfullscreen>
                    </iframe>
                </div>
            </article>
            <article class="clip-card">
                <p>COMING SOON</p>
            </article>
            <article class="clip-card">
                <p>COMING SOON</p>
            </article>
        </div>
    </section>

    <!-- About Me -->
    <section id="about-me" class="section alt">
        <div class="section-heading">
            <h2>About Me</h2>
            <p>15 years old FPV pilot.</p>
        </div>
        <div class="two-column">
            <p>I started flying drones since I was 9 years old. At first they were these cheap china drones with the 720p camera .</p>
            <p>Now I'm flying with serious equipment and some skill. I love flying in nice landscape scenarios, they are just beautiful.</p>
            <p>I also work for clients, if you are interested then DM me per Instagram. I will respond as soon as possible</p>
        </div>
    </section>


    <!-- Milestones -->
    <section id="milestones" class="section alt">
        <div class="section-heading">
            <h2>Milestones</h2>
            <p>Important points across the journey.</p>
        </div>
        <ol class="timeline">
            <li>
                <h3>2020 - My first ever drone flight with a "legendary" 80 bucks drone</h3>
                <p>Getting comfortable with flying drone.</p>
            </li>
            <li>
                <h3>2024 - Bought my first ever quality drone</h3>
                <p>I bought in December 2024 my first DJI Mini 3 </p>
            </li>
            <li>
                <h3>2025 - Gathering informations about FPV</h3>
                <p>Up until July I did really much research about FPV and bought the DJI FPV.</p>
            </li>
            <li>
                <h3>March 2026</h3>
                <p>Built the 5".</p>
                <p>First clips with my 5".</p>
            </li>
        </ol>
    </section>

    <!-- Achievements -->
    <section id="achievements" class="section">
        <div class="section-heading">
            <h2>Achievements</h2>
            <p>A1 C0 Drone Licence</p>
            <p>Finished building my 5"</p>	 
        </div>
        <ul class="achievement-list">
            <li>First heard of FPV Drones.</li>
            <li>First ever FPV Drone: DJI FPV.</li>
            <li>First 20 Hours in my Sim.</li>
            <li>My first build ever: 5" Quad.</li>
        </ul>
    </section>

    <!-- Impressum -->
    <div class="impressum-box">
        <p><strong>Name:</strong> Finn Ryf</p>
