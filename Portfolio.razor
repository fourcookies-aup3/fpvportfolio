@page "/portfolio"

<header class="hero" id="top">
    <NavMenu />

    <div class="hero-content">
        <p class="eyebrow">Portfolio</p>
        <h1>FPV Drone Journey of me.</h1>
        <p>This portfolio introduces you to the background story of my Journey up until now. Check out my socials!</p>
        <a class="cta" href="#builds">Explore Work</a>

    </div>
</header>

<main>
